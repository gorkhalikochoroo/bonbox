{
	"appId": "dk.bonbox.app",
	"appName": "BonBox",
	"webDir": "dist",
	"ios": {
		"contentInset": "automatic",
		"allowsLinkPreview": false,
		"backgroundColor": "#0d1117",
		"scrollEnabled": true
	},
	"android": {
		"backgroundColor": "#0d1117"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0d1117",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0d1117"
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"CAPCameraPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"CAPNetworkPlugin",
		"PreferencesPlugin",
		"PushNotificationsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
